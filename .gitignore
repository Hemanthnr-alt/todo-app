# ============================================
# ENV FILES — NEVER COMMIT THESE
# ============================================
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
frontend/.env
frontend/.env.*
backend/.env
backend/.env.*
# Allow example files
!.env.example
!frontend/.env.example
!backend/.env.example

# ============================================
# Dependencies
# ============================================
node_modules/
frontend/node_modules/
backend/node_modules/

# ============================================
# Build outputs
# ============================================
dist/
frontend/dist/
build/
frontend/build/

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# Uploads (user data — don't commit)
# ============================================
backend/uploads/

# ============================================
# OS / Editor
# ============================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================
# Misc
# ============================================
*.local
.cache/
coverage/
